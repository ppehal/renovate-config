{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    "helpers:pinGitHubActionDigests",
    ":disablePeerDependencies"
  ],
  "labels": [
    "dependencies"
  ],
  "schedule": [
    "before 6am on Monday"
  ],
  "timezone": "Europe/Prague",
  "prHourlyLimit": 3,
  "prConcurrentLimit": 5,
  "automergeType": "pr",
  "platformAutomerge": true,
  "lockFileMaintenance": {
    "enabled": true,
    "automerge": true
  },
  "packageRules": [
    {
      "description": "[1] Patch+minor automerge \u2014 stable packages (>=1.0.0)",
      "matchUpdateTypes": [
        "patch",
        "minor"
      ],
      "matchCurrentVersion": ">=1.0.0",
      "automerge": true
    },
    {
      "description": "[2] Patch automerge \u2014 0.x packages (patch is safe in practice)",
      "matchUpdateTypes": [
        "patch"
      ],
      "matchCurrentVersion": "<1.0.0",
      "automerge": true
    },
    {
      "description": "[3] Pre-release: never automerge (matches proposed version)",
      "matchNewValue": "/-(alpha|beta|rc|canary)/",
      "automerge": false
    },
    {
      "description": "[4] Next.js ecosystem \u2014 group for clean PRs",
      "matchPackageNames": [
        "/^next$/",
        "/^@next\\//",
        "eslint-config-next"
      ],
      "groupName": "Next.js ecosystem"
    },
    {
      "description": "[5] Prisma \u2014 group for clean PRs",
      "matchPackageNames": [
        "/^prisma$/",
        "/^@prisma\\//"
      ],
      "groupName": "Prisma"
    },
    {
      "description": "[6] Testing tools \u2014 group",
      "matchPackageNames": [
        "/^vitest$/",
        "/^@vitest\\//",
        "/^@vitejs\\//",
        "/^@testing-library\\//",
        "/^@playwright\\//",
        "playwright"
      ],
      "groupName": "Testing"
    },
    {
      "description": "[7] Lint and format \u2014 group",
      "matchPackageNames": [
        "/^eslint$/",
        "/^eslint-/",
        "/^@eslint\\//",
        "typescript-eslint",
        "/^prettier$/",
        "prettier-plugin-tailwindcss",
        "/^@commitlint\\//",
        "commitizen",
        "husky",
        "lint-staged",
        "globals"
      ],
      "groupName": "Lint and Format"
    },
    {
      "description": "[8] TypeScript + @types \u2014 group",
      "matchPackageNames": [
        "typescript",
        "/^@types\\//"
      ],
      "groupName": "TypeScript"
    },
    {
      "description": "[9] Docker \u2014 pin digests",
      "matchDatasources": [
        "docker"
      ],
      "pinDigests": true
    },
    {
      "description": "[10] Pin dependencies \u2014 automerge (safe, no version change)",
      "matchUpdateTypes": [
        "pin"
      ],
      "automerge": true
    },
    {
      "description": "[11] Major updates \u2014 manual + dashboard approval. ONLY explicit automerge:false.",
      "matchUpdateTypes": [
        "major"
      ],
      "automerge": false,
      "dependencyDashboardApproval": true
    }
  ],
  "vulnerabilityAlerts": {
    "enabled": true,
    "labels": [
      "dependencies",
      "security"
    ],
    "schedule": [
      "at any time"
    ],
    "automerge": true
  },
  "osvVulnerabilityAlerts": {
    "enabled": true,
    "labels": [
      "dependencies",
      "security"
    ],
    "automerge": true
  },
  "transitiveRemediation": true,
  "hostRules": [
    {
      "matchHost": "https://npm.pkg.github.com/",
      "hostType": "npm",
      "token": "{{ secrets.GH_PACKAGES_TOKEN }}"
    }
  ]
}
